{% extends 'base.html.twig' %}

{% block title %}Dashboard - ORS Labs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .dashboard-header {
            text-align: center;
            padding: 3rem 0 2rem;
        }

        .dashboard-title {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 700;
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
        }

        .dashboard-subtitle {
            color: var(--text-secondary);
            font-size: 1.1rem;
        }

        .welcome-card {
            background: white;
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
            margin-bottom: 2rem;
            border-left: 4px solid var(--accent);
        }

        .welcome-card h2 {
            color: var(--primary);
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        .welcome-card p {
            color: var(--text-secondary);
            line-height: 1.6;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--gradient-accent);
        }

        .stat-label {
            color: var(--text-secondary);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
        }

        .stat-description {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-top: 0.5rem;
        }

        .reports-section {
            margin-top: 3rem;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            color: var(--primary);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .section-title::after {
            content: '';
            flex: 1;
            height: 2px;
            background: var(--border);
        }

        .reports-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .report-card {
            background: white;
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
            transition: all 0.3s ease;
            cursor: pointer;
            border: 2px solid transparent;
        }

        .report-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.12);
            border-color: var(--accent);
        }

        .report-card.latest {
            border-color: var(--accent);
            position: relative;
        }

        .report-card.latest::after {
            content: 'Dernier';
            position: absolute;
            top: 12px;
            right: 12px;
            background: var(--gradient-accent);
            color: white;
            font-size: 0.7rem;
            font-weight: 700;
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .report-date {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .report-meta {
            display: flex;
            gap: 1rem;
            color: var(--text-secondary);
            font-size: 0.85rem;
            margin-bottom: 1rem;
        }

        .report-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border);
        }

        .report-stat {
            text-align: center;
        }

        .report-stat-value {
            font-weight: 700;
            color: var(--primary);
            font-size: 1.25rem;
        }

        .report-stat-label {
            color: var(--text-secondary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
        }

        .empty-state-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        .empty-state-title {
            font-size: 1.5rem;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
        }

        .empty-state-text {
            color: var(--text-secondary);
        }

        /* ===== Charts Section ===== */
        .charts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 1.5rem;
            margin-top: 1rem;
            margin-bottom: 2rem;
        }

        .chart-card {
            background: white;
            border-radius: 14px;
            padding: 1.5rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

        .chart-card h3 {
            font-size: 0.95rem;
            color: var(--primary);
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .chart-card canvas {
            max-height: 220px;
        }

        @media (max-width: 768px) {
            .dashboard-title {
                font-size: 2rem;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }

            .reports-grid {
                grid-template-columns: 1fr;
            }

            .charts-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="dashboard-header">
        <h1 class="dashboard-title">Dashboard SEO</h1>
        <p class="dashboard-subtitle">Vue d'ensemble de vos rapports mensuels</p>
    </div>

    <div class="welcome-card">
        <h2>👋 Bonjour {{ user.firstName }} !</h2>
        <p>Bienvenue sur votre tableau de bord SEO. Vous pouvez consulter ici l'historique complet de vos rapports mensuels et suivre l'évolution de vos performances.</p>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Rapports disponibles</div>
            <div class="stat-value">4</div>
            <div class="stat-description">Novembre 2025 à Février 2026</div>
        </div>

        <div class="stat-card" style="border-top-color: var(--success);">
            <div class="stat-label">Dernier rapport</div>
            <div class="stat-value">Fév 2026</div>
            <div class="stat-description">Publié récemment</div>
        </div>

        <div class="stat-card" style="border-top-color: var(--warning);">
            <div class="stat-label">Période couverte</div>
            <div class="stat-value">4 mois</div>
            <div class="stat-description">Nov 2025 - Fév 2026</div>
        </div>
    </div>

    {# ===== Graphiques SEO ===== #}
    {% if seoChartData is defined and seoChartData.labels|default([])|length > 1 %}
        <div class="reports-section">
            <h2 class="section-title">📈 Évolution des performances</h2>
            <div class="charts-grid">
                <div class="chart-card">
                    <h3>Impressions & Clics</h3>
                    <canvas id="seoTrafficChart"></canvas>
                </div>
                <div class="chart-card">
                    <h3>Trafic organique & Utilisateurs</h3>
                    <canvas id="seoSessionsChart"></canvas>
                </div>
            </div>
        </div>
    {% endif %}

    <div class="reports-section">
        <h2 class="section-title">📊 Rapports mensuels</h2>

        <div class="reports-grid">
            <!-- Rapport Février 2026 -->
            <div class="report-card latest" onclick="alert('Fonctionnalité à venir : consultation du rapport Février 2026')">
                <div class="report-date">Février 2026</div>
                <div class="report-meta">
                    <span>📅 01/02 - 28/02/2026</span>
                </div>
                <p style="color: var(--text-secondary); font-size: 0.9rem;">
                    Baisse significative du trafic mais amélioration continue de la visibilité SEO et du classement (position 13).
                </p>
                <div class="report-stats">
                    <div class="report-stat">
                        <div class="report-stat-value">21,779</div>
                        <div class="report-stat-label">Impressions</div>
                    </div>
                    <div class="report-stat">
                        <div class="report-stat-value">147</div>
                        <div class="report-stat-label">Sessions</div>
                    </div>
                    <div class="report-stat">
                        <div class="report-stat-value">1.00%</div>
                        <div class="report-stat-label">CTR</div>
                    </div>
                    <div class="report-stat">
                        <div class="report-stat-value">Position 13</div>
                        <div class="report-stat-label">Classement</div>
                    </div>
                </div>
            </div>

            <!-- Rapport Janvier 2026 -->
            <div class="report-card" onclick="alert('Fonctionnalité à venir : consultation du rapport Janvier 2026')">
                <div class="report-date">Janvier 2026</div>
                <div class="report-meta">
                    <span>📅 01/01 - 31/01/2026</span>
                </div>
                <p style="color: var(--text-secondary); font-size: 0.9rem;">
                    Reprise post-fêtes avec croissance du trafic direct et maintien du trafic organique.
                </p>
                <div class="report-stats">
                    <div class="report-stat">
                        <div class="report-stat-value">20,334</div>
                        <div class="report-stat-label">Impressions</div>
                    </div>
                    <div class="report-stat">
                        <div class="report-stat-value">215</div>
                        <div class="report-stat-label">Sessions</div>
                    </div>
                    <div class="report-stat">
                        <div class="report-stat-value">1.20%</div>
                        <div class="report-stat-label">CTR</div>
                    </div>
                    <div class="report-stat">
                        <div class="report-stat-value">Position 15</div>
                        <div class="report-stat-label">Classement</div>
                    </div>
                </div>
            </div>

            <!-- Rapport Décembre 2025 -->
            <div class="report-card" onclick="alert('Fonctionnalité à venir : consultation du rapport Décembre 2025')">
                <div class="report-date">Décembre 2025</div>
                <div class="report-meta">
                    <span>📅 01/12 - 31/12/2025</span>
                </div>
                <p style="color: var(--text-secondary); font-size: 0.9rem;">
                    Ralentissement temporaire dû aux effets saisonniers, mais amélioration notable de l'engagement.
                </p>
                <div class="report-stats">
                    <div class="report-stat">
                        <div class="report-stat-value">19,222</div>
                        <div class="report-stat-label">Impressions</div>
                    </div>
                    <div class="report-stat">
                        <div class="report-stat-value">208</div>
                        <div class="report-stat-label">Sessions</div>
                    </div>
                    <div class="report-stat">
                        <div class="report-stat-value">1.30%</div>
                        <div class="report-stat-label">CTR</div>
                    </div>
                    <div class="report-stat">
                        <div class="report-stat-value">Position 16</div>
                        <div class="report-stat-label">Classement</div>
                    </div>
                </div>
            </div>

            <!-- Rapport Novembre 2025 -->
            <div class="report-card" onclick="alert('Fonctionnalité à venir : consultation du rapport Novembre 2025')">
                <div class="report-date">Novembre 2025</div>
                <div class="report-meta">
                    <span>📅 01/11 - 30/11/2025</span>
                </div>
                <p style="color: var(--text-secondary); font-size: 0.9rem;">
                    Croissance continue du trafic organique et direct, avec une visibilité en amélioration.
                </p>
                <div class="report-stats">
                    <div class="report-stat">
                        <div class="report-stat-value">17,910</div>
                        <div class="report-stat-label">Impressions</div>
                    </div>
                    <div class="report-stat">
                        <div class="report-stat-value">261</div>
                        <div class="report-stat-label">Sessions</div>
                    </div>
                    <div class="report-stat">
                        <div class="report-stat-value">1.70%</div>
                        <div class="report-stat-label">CTR</div>
                    </div>
                    <div class="report-stat">
                        <div class="report-stat-value">Position 14</div>
                        <div class="report-stat-label">Classement</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="reports-section">
        <h2 class="section-title">Prochaines étapes</h2>

        <div class="welcome-card" style="border-left-color: var(--warning);">
            <h2 style="color: var(--warning);">Actions recommandées</h2>
            <ul style="color: var(--text-secondary); line-height: 2; margin-top: 1rem;">
                <li><strong>Priorité 1 :</strong> Améliorer le CTR — Optimiser titres et meta descriptions sur les pages à forte visibilité</li>
                <li><strong>Priorité 2 :</strong> Surveiller la tendance du trafic — La baisse de février (-42% utilisateurs) doit être observée sur mars/avril</li>
                <li><strong>Priorité 3 :</strong> Exploiter le contenu PDF technique — Transformer les PDF performants en pages HTML optimisées</li>
                <li><strong>Priorité 4 :</strong> Maillage interne et contenu — Restructurer les pages pour améliorer position et engagement</li>
            </ul>
        </div>

        <div class="welcome-card" style="border-left-color: var(--success);">
            <h2 style="color: var(--success);">Actions en cours</h2>
            <ul style="color: var(--text-secondary); line-height: 2; margin-top: 1rem;">
                <li>📝 Publication du contenu proposé sur /outils/conversions-dhumidite/ — <em>En attente d'approbation par ORSLabs</em></li>
                <li>📝 Refonte du contenu /tests-dhermeticite/hshld/ — <em>En attente d'approbation d'une optimisation de la structure par ORSLabs</em></li>
                <li>📝 Conversion PDF → HTML (Variable_leak_rate_phenomena_in_glass_to_metal_seals.pdf) — <em>En attente d'approbation par ORSLabs</em></li>
            </ul>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    {% if seoChartData is defined and seoChartData.labels|default([])|length > 1 %}
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
        <script>
            const chartDefaults = {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            usePointStyle: true,
                            padding: 16,
                            font: { family: 'Inter', size: 12 }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { font: { family: 'Inter', size: 11 } }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { color: '#f1f5f9' },
                        ticks: { font: { family: 'Inter', size: 11 } }
                    }
                }
            };

            // Impressions & Clics
            new Chart(document.getElementById('seoTrafficChart'), {
                type: 'bar',
                data: {
                    labels: {{ seoChartData.labels|json_encode|raw }},
                    datasets: [
                        {
                            label: 'Impressions',
                            data: {{ seoChartData.datasets.impressions|json_encode|raw }},
                            backgroundColor: 'rgba(30, 58, 138, 0.7)',
                            borderRadius: 6,
                            barPercentage: 0.6,
                        },
                        {
                            label: 'Clics',
                            data: {{ seoChartData.datasets.clicks|json_encode|raw }},
                            backgroundColor: 'rgba(6, 182, 212, 0.7)',
                            borderRadius: 6,
                            barPercentage: 0.6,
                        }
                    ]
                },
                options: chartDefaults
            });

            // Sessions & Utilisateurs
            new Chart(document.getElementById('seoSessionsChart'), {
                type: 'line',
                data: {
                    labels: {{ seoChartData.labels|json_encode|raw }},
                    datasets: [
                        {
                            label: 'Sessions organiques',
                            data: {{ seoChartData.datasets.organicSessions|json_encode|raw }},
                            borderColor: '#059669',
                            backgroundColor: 'rgba(5, 150, 105, 0.1)',
                            fill: true,
                            tension: 0.4,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                        },
                        {
                            label: 'Utilisateurs uniques',
                            data: {{ seoChartData.datasets.totalUsers|json_encode|raw }},
                            borderColor: '#F59E0B',
                            backgroundColor: 'rgba(245, 158, 11, 0.1)',
                            fill: true,
                            tension: 0.4,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                        }
                    ]
                },
                options: chartDefaults
            });
        </script>
    {% endif %}
{% endblock %}



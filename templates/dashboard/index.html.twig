{% extends 'base.html.twig' %}

{% block title %}Dashboard - ORS Labs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .dashboard-header {
            text-align: center;
            padding: 3rem 0 2rem;
        }

        .dashboard-title {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 700;
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
        }

        .dashboard-subtitle {
            color: var(--text-secondary);
            font-size: 1.1rem;
        }

        .welcome-card {
            background: white;
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
            margin-bottom: 2rem;
            border-left: 4px solid var(--accent);
        }

        .welcome-card h2 {
            color: var(--primary);
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        .welcome-card p {
            color: var(--text-secondary);
            line-height: 1.6;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--gradient-accent);
        }

        .stat-label {
            color: var(--text-secondary);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
        }

        .stat-description {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-top: 0.5rem;
        }

        .reports-section {
            margin-top: 3rem;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            color: var(--primary);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .section-title::after {
            content: '';
            flex: 1;
            height: 2px;
            background: var(--border);
        }

        .reports-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .report-card {
            background: white;
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
            transition: all 0.3s ease;
            cursor: pointer;
            border: 2px solid transparent;
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .report-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.12);
            border-color: var(--accent);
        }

        .report-card.latest {
            border-color: var(--accent);
            box-shadow: 0 4px 12px rgba(6, 182, 212, 0.15);
        }

        .report-card.latest::before {
            content: 'Dernier';
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            background: var(--gradient-accent);
            color: white;
            font-size: 0.7rem;
            font-weight: 700;
            padding: 0.25rem 0.6rem;
            border-radius: 999px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .report-card {
            position: relative;
        }

        .report-date {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .report-meta {
            display: flex;
            gap: 1rem;
            color: var(--text-secondary);
            font-size: 0.85rem;
            margin-bottom: 1rem;
        }

        .report-description {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-bottom: 1rem;
            line-height: 1.5;
        }

        .report-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border);
        }

        .report-stat {
            text-align: center;
        }

        .report-stat-value {
            font-weight: 700;
            color: var(--primary);
            font-size: 1.25rem;
        }

        .report-stat-label {
            color: var(--text-secondary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
        }

        .empty-state-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        .empty-state-title {
            font-size: 1.5rem;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
        }

        .empty-state-text {
            color: var(--text-secondary);
        }

        .view-all-link {
            text-align: center;
            margin-top: 2rem;
        }

        @media (max-width: 768px) {
            .dashboard-title {
                font-size: 2rem;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }

            .reports-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="dashboard-header">
    <h1 class="dashboard-title">Dashboard SEO</h1>
    <p class="dashboard-subtitle">Vue d'ensemble de vos rapports mensuels</p>
</div>

<div class="welcome-card">
    <h2>👋 Bonjour {{ user.firstName }} !</h2>
    <p>Bienvenue sur votre tableau de bord SEO. Vous pouvez consulter ici l'historique complet de vos rapports mensuels et suivre l'évolution de vos performances.</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Rapports disponibles</div>
        <div class="stat-value">{{ totalReports }}</div>
        <div class="stat-description">
            {% if totalReports > 0 %}
                Période : {{ periodCovered }}
            {% else %}
                Aucun rapport
            {% endif %}
        </div>
    </div>

    <div class="stat-card" style="border-top-color: var(--success);">
        <div class="stat-label">Dernier rapport</div>
        <div class="stat-value">
            {% if latestReport %}
                {{ latestReport.monthName }}
            {% else %}
                N/A
            {% endif %}
        </div>
        <div class="stat-description">
            {% if latestReport %}
                {{ latestReport.summary }}
            {% else %}
                Aucun rapport disponible
            {% endif %}
        </div>
    </div>

    <div class="stat-card" style="border-top-color: var(--warning);">
        <div class="stat-label">Période couverte</div>
        <div class="stat-value">{{ periodCovered }}</div>
        <div class="stat-description">Historique complet</div>
    </div>
</div>

<div class="reports-section">
    <h2 class="section-title">📊 Rapports mensuels</h2>

    {% if reports is empty %}
        <div class="welcome-card" style="text-align: center; border-left-color: var(--warning);">
            <h2 style="color: var(--warning);">📭 Aucun rapport disponible</h2>
            <p>Pour ajouter des rapports :</p>
            <ol style="text-align: left; max-width: 600px; margin: 1rem auto;">
                <li>Placez vos fichiers HTML dans <code>public/reports/</code></li>
                <li>Nommez-les selon la convention : <code>2026-04.html</code></li>
                <li>Exécutez : <code>php bin/console app:sync-reports</code></li>
            </ol>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_reports_sync') }}" class="btn btn-primary" style="margin-top: 1rem;">
                    Synchroniser maintenant
                </a>
            {% endif %}
        </div>
    {% else %}
        <div class="reports-grid">
            {% for report in reports|slice(0, 6) %}
                <a href="{{ path('app_report_view', {period: report.period}) }}"
                   class="report-card{% if loop.first %} latest{% endif %}">
                    <div class="report-date">{{ report.monthName }}</div>

                    {% if report.reportDate %}
                        <div class="report-meta">
                            <span>📅 01/{{ report.reportDate|date('m/Y') }} - {{ report.reportDate|date('t/m/Y') }}</span>
                        </div>
                    {% endif %}

                    {% if report.description %}
                        <p class="report-description">{{ report.description }}</p>
                    {% endif %}

                    {% if report.impressions or report.organicSessions or report.ctr or report.position %}
                        <div class="report-stats">
                            {% if report.impressions %}
                                <div class="report-stat">
                                    <div class="report-stat-value">{{ report.impressions|number_format(0, ',', ' ') }}</div>
                                    <div class="report-stat-label">Impressions</div>
                                </div>
                            {% endif %}

                            {% if report.organicSessions %}
                                <div class="report-stat">
                                    <div class="report-stat-value">{{ report.organicSessions }}</div>
                                    <div class="report-stat-label">Sessions</div>
                                </div>
                            {% endif %}

                            {% if report.ctr %}
                                <div class="report-stat">
                                    <div class="report-stat-value">{{ report.ctr|number_format(2) }}%</div>
                                    <div class="report-stat-label">CTR</div>
                                </div>
                            {% endif %}

                            {% if report.position %}
                                <div class="report-stat">
                                    <div class="report-stat-value">Position {{ report.position }}</div>
                                    <div class="report-stat-label">Classement</div>
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}
                </a>
            {% endfor %}
        </div>

        {% if totalReports > 6 %}
            <div class="view-all-link">
                <a href="{{ path('app_reports_list') }}" class="btn btn-primary">
                    Voir tous les rapports ({{ totalReports }})
                </a>
            </div>
        {% endif %}
    {% endif %}
</div>

<div class="reports-section">
    <h2 class="section-title">🎯 Prochaines étapes</h2>

    <div class="welcome-card" style="border-left-color: var(--warning);">
        <h2 style="color: var(--warning);">Actions recommandées</h2>
        <p style="margin-top: 0.5rem;">
            {% if latestReport %}
                D'après le rapport <strong>{{ latestReport.monthName }}</strong> :
            {% else %}
                Priorités stratégiques pour les prochains mois :
            {% endif %}
        </p>
        <ul style="color: var(--text-secondary); line-height: 2; margin-top: 1rem;">
            <li><strong>Priorité 1 :</strong> Améliorer le CTR sur les pages à fortes impressions (optimisation titres et meta descriptions)</li>
            <li><strong>Priorité 2 :</strong> Renforcer le maillage interne pour prolonger la durée des sessions</li>
            <li><strong>Priorité 3 :</strong> Continuer l'optimisation des pages outils (Moisture Calculator, Humidity Conversion Tool)</li>
            <li><strong>Priorité 4 :</strong> Valoriser les contenus PDF techniques en les transformant en pages d'atterrissage optimisées</li>
        </ul>
    </div>
</div>
{% endblock %}

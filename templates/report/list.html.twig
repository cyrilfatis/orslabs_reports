{% extends 'base.html.twig' %}

{% block title %}Rapports SEO - ORS Labs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            color: var(--primary);
        }

        .sync-button {
            background: var(--gradient-accent);
            color: white;
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }

        .sync-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(6, 182, 212, 0.3);
        }

        .reports-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }

        /* Card wrapper pour positionner les boutons */
        .report-card-wrapper {
            position: relative;
        }

        .report-card {
            background: white;
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
            transition: all 0.3s ease;
            border: 2px solid transparent;
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .report-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.12);
            border-color: var(--accent);
        }

        .report-period {
            font-family: 'Playfair Display', serif;
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .report-title {
            color: var(--text-secondary);
            font-size: 0.95rem;
            margin-bottom: 1rem;
        }

        .report-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border);
        }

        .report-stat {
            text-align: center;
        }

        .report-stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            display: block;
        }

        .report-stat-label {
            font-size: 0.75rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ===== Boutons d'action (coin supérieur droit de la carte) ===== */
        .report-actions-overlay {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            display: flex;
            gap: 0.4rem;
            opacity: 0;
            transition: opacity 0.3s ease;
            z-index: 2;
        }

        .report-card-wrapper:hover .report-actions-overlay {
            opacity: 1;
        }

        .report-action-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.35rem 0.65rem;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        /* Bouton PDF original — style accent */
        .report-action-btn--pdf {
            background: var(--gradient-primary);
            color: white;
        }

        .report-action-btn--pdf:hover {
            transform: scale(1.05);
            box-shadow: 0 2px 8px rgba(30, 58, 138, 0.4);
        }

        /* Bouton Export Dompdf — style secondaire */
        .report-action-btn--export {
            background: var(--gradient-accent);
            color: white;
        }

        .report-action-btn--export:hover {
            transform: scale(1.05);
            box-shadow: 0 2px 8px rgba(6, 182, 212, 0.4);
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
        }

        .empty-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        @media (max-width: 768px) {
            .page-header {
                flex-direction: column;
                gap: 1rem;
                align-items: flex-start;
            }

            .reports-grid {
                grid-template-columns: 1fr;
            }

            /* Toujours visible sur mobile (pas de hover) */
            .report-actions-overlay {
                opacity: 1;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page-header">
        <h1 class="page-title">📊 Rapports SEO</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_reports_sync') }}" class="sync-button">
                🔄 Synchroniser les rapports
            </a>
        {% endif %}
    </div>

    {% if reports is empty %}
        <div class="empty-state">
            <div class="empty-icon">🔭</div>
            <h2 style="color: var(--text-secondary); margin-bottom: 1rem;">Aucun rapport disponible</h2>
            <p style="color: var(--text-secondary); margin-bottom: 2rem;">
                Placez vos fichiers HTML dans le dossier <code>public/reports/</code><br>
                avec la convention de nommage : <code>2025-11.html</code>
            </p>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_reports_sync') }}" class="btn btn-primary">
                    Synchroniser maintenant
                </a>
            {% endif %}
        </div>
    {% else %}
        <div class="reports-grid">
            {% for report in reports %}
                <div class="report-card-wrapper">
                    <a href="{{ path('app_report_view', {period: report.period}) }}" class="report-card">
                        <div class="report-period">{{ report.monthName }}</div>
                        <div class="report-title">{{ report.description }}</div>

                        {% if report.impressions or report.organicSessions %}
                            <div class="report-stats">
                                {% if report.impressions %}
                                    <div class="report-stat">
                                        <span class="report-stat-value">{{ report.impressions|number_format(0, ',', ' ') }}</span>
                                        <span class="report-stat-label">Impressions</span>
                                    </div>
                                {% endif %}

                                {% if report.organicSessions %}
                                    <div class="report-stat">
                                        <span class="report-stat-value">{{ report.organicSessions }}</span>
                                        <span class="report-stat-label">Sessions</span>
                                    </div>
                                {% endif %}

                                {% if report.ctr %}
                                    <div class="report-stat">
                                        <span class="report-stat-value">{{ report.ctr|number_format(2) }}%</span>
                                        <span class="report-stat-label">CTR</span>
                                    </div>
                                {% endif %}

                                {% if report.position %}
                                    <div class="report-stat">
                                        <span class="report-stat-value">{{ report.position }}</span>
                                        <span class="report-stat-label">Position</span>
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}
                    </a>

                    {# ===== Boutons de téléchargement ===== #}
                    <div class="report-actions-overlay">
                        {# PDF original (seulement si un fichier PDF est associé) #}
                        {% if report.hasPdf %}
                            <a href="{{ path('app_report_download_pdf', {period: report.period}) }}"
                               class="report-action-btn report-action-btn--pdf"
                               title="Télécharger le rapport PDF original">
                                📄 PDF Original
                            </a>
                        {% endif %}

                        {# Export HTML → PDF via Dompdf #}
{#                        <a href="{{ path('app_report_export_pdf', {period: report.period}) }}"#}
{#                           class="report-action-btn report-action-btn--export"#}
{#                           title="Exporter le rapport HTML en PDF">#}
{#                            📥 Export#}
{#                        </a>#}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}




{% extends 'base.htxxml.twig' %}

{% block title %}Dashboard - ORS Labs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ===== Dashboard Layout ===== */
        .dashboard-header {
            text-align: center;
            padding: 2.5rem 0 1.5rem;
        }

        .dashboard-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            font-weight: 700;
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.25rem;
        }

        .dashboard-subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .dashboard-period {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin-top: 0.75rem;
            padding: 0.4rem 1rem;
            background: white;
            border-radius: 20px;
            font-size: 0.85rem;
            color: var(--text-secondary);
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

        .dashboard-period .dot {
            width: 8px;
            height: 8px;
            background: var(--success);
            border-radius: 50%;
            animation: pulse-dot 2s infinite;
        }

        @keyframes pulse-dot {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        /* ===== Section Headers ===== */
        .section-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin: 2.5rem 0 1.25rem;
        }

        .section-header .section-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .section-header .section-icon.seo { background: rgba(30, 58, 138, 0.1); color: var(--primary); }
        .section-header .section-icon.linkedin { background: rgba(10, 102, 194, 0.1); color: #0A66C2; }
        .section-header .section-icon.reports { background: rgba(6, 182, 212, 0.1); color: var(--accent); }

        .section-header h2 {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            color: var(--primary);
            margin: 0;
        }

        .section-header::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        /* ===== KPI Grid ===== */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }

        .kpi-grid.compact {
            grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
        }

        .kpi-card {
            background: white;
            border-radius: 14px;
            padding: 1.25rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
            position: relative;
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .kpi-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1);
        }

        .kpi-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
        }

        .kpi-card.primary::before { background: var(--gradient-primary); }
        .kpi-card.accent::before { background: var(--gradient-accent); }
        .kpi-card.success::before { background: linear-gradient(135deg, #059669, #10B981); }
        .kpi-card.linkedin::before { background: linear-gradient(135deg, #0A66C2, #0077B5); }
        .kpi-card.warning::before { background: linear-gradient(135deg, #F59E0B, #FBBF24); }

        .kpi-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: var(--text-secondary);
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .kpi-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.2;
        }

        .kpi-card.linkedin .kpi-value { color: #0A66C2; }

        .kpi-trend {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            font-size: 0.78rem;
            font-weight: 600;
            margin-top: 0.5rem;
            padding: 0.15rem 0.5rem;
            border-radius: 12px;
        }

        .kpi-trend.up {
            color: #059669;
            background: rgba(5, 150, 105, 0.1);
        }

        .kpi-trend.down {
            color: #DC2626;
            background: rgba(220, 38, 38, 0.1);
        }

        .kpi-trend.neutral {
            color: var(--text-secondary);
            background: rgba(100, 116, 139, 0.1);
        }

        .kpi-trend svg {
            width: 12px;
            height: 12px;
        }

        /* ===== LinkedIn Highlight Banner ===== */
        .linkedin-banner {
            background: linear-gradient(135deg, #0A66C2 0%, #004182 100%);
            border-radius: 16px;
            padding: 1.5rem 2rem;
            color: white;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin-bottom: 1rem;
            position: relative;
            overflow: hidden;
        }

        .linkedin-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
        }

        .linkedin-banner .li-icon {
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,0.15);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .linkedin-banner .li-icon svg {
            width: 28px;
            height: 28px;
            fill: white;
        }

        .linkedin-banner .li-content h3 {
            font-size: 1.1rem;
            margin-bottom: 0.25rem;
            font-weight: 600;
        }

        .linkedin-banner .li-content p {
            font-size: 0.85rem;
            opacity: 0.85;
            margin: 0;
        }

        .linkedin-banner .li-stats {
            display: flex;
            gap: 1.5rem;
            margin-left: auto;
            position: relative;
            z-index: 1;
        }

        .linkedin-banner .li-stat {
            text-align: center;
        }

        .linkedin-banner .li-stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            display: block;
        }

        .linkedin-banner .li-stat-label {
            font-size: 0.7rem;
            opacity: 0.75;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ===== Charts Section ===== */
        .charts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 1.5rem;
            margin-top: 1rem;
        }

        .chart-card {
            background: white;
            border-radius: 14px;
            padding: 1.5rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

        .chart-card h3 {
            font-size: 0.95rem;
            color: var(--text-primary);
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .chart-card canvas {
            max-height: 220px;
        }

        /* ===== Reports Grid ===== */
        .reports-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1rem;
        }

        .report-card {
            background: white;
            border-radius: 14px;
            padding: 1.25rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
            transition: all 0.2s ease;
            cursor: pointer;
            border: 2px solid transparent;
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .report-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
            border-color: var(--accent);
        }

        .report-date {
            font-family: 'Playfair Display', serif;
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 0.25rem;
        }

        .report-description {
            color: var(--text-secondary);
            font-size: 0.8rem;
            margin-bottom: 0.75rem;
        }

        .report-mini-stats {
            display: flex;
            gap: 1rem;
            padding-top: 0.75rem;
            border-top: 1px solid var(--border);
        }

        .report-mini-stat {
            text-align: center;
            flex: 1;
        }

        .report-mini-stat-value {
            font-weight: 700;
            color: var(--primary);
            font-size: 1rem;
        }

        .report-mini-stat-label {
            color: var(--text-secondary);
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .view-all-link {
            text-align: center;
            margin-top: 1.5rem;
        }

        /* ===== Empty State ===== */
        .empty-state {
            background: white;
            border-radius: 16px;
            padding: 2.5rem;
            text-align: center;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

        .empty-state h3 {
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .empty-state p {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        /* ===== Responsive ===== */
        @media (max-width: 768px) {
            .dashboard-title { font-size: 1.8rem; }
            .kpi-grid { grid-template-columns: repeat(2, 1fr); }
            .charts-grid { grid-template-columns: 1fr; }
            .reports-grid { grid-template-columns: 1fr; }
            .linkedin-banner {
                flex-direction: column;
                text-align: center;
            }
            .linkedin-banner .li-stats { margin-left: 0; }
            .kpi-value { font-size: 1.4rem; }
        }

        @media (max-width: 480px) {
            .kpi-grid { grid-template-columns: 1fr; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="dashboard-header">
    <h1 class="dashboard-title">Tableau de bord SEO</h1>
    <p class="dashboard-subtitle">Performances digitales — {{ user.firstName }}, bienvenue !</p>
    {% if latestSeo %}
        <div class="dashboard-period">
            <span class="dot"></span>
            Dernière mise à jour : {{ latestSeo.monthName }}
        </div>
    {% endif %}
</div>

{# ===== SECTION : KPIs SEO ===== #}
{% if latestSeo %}
<div class="section-header">
    <div class="section-icon seo">📊</div>
    <h2>Performance SEO</h2>
</div>

<div class="kpi-grid">
    {# Impressions #}
    <div class="kpi-card primary">
        <div class="kpi-label">Impressions</div>
        <div class="kpi-value">{{ latestSeo.impressions|default(0)|number_format(0, ',', ' ') }}</div>
        {% if seoTrends.impressions.value is defined and seoTrends.impressions.value %}
            <div class="kpi-trend {{ seoTrends.impressions.direction }}">
                {% if seoTrends.impressions.direction == 'up' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M7 17l5-5 5 5M7 7l5 5 5-5"/></svg>
                {% elseif seoTrends.impressions.direction == 'down' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M7 7l5 5 5-5M7 17l5-5 5 5"/></svg>
                {% endif %}
                {{ seoTrends.impressions.value }} vs mois précédent
            </div>
        {% endif %}
    </div>

    {# Clics #}
    <div class="kpi-card primary">
        <div class="kpi-label">Clics</div>
        <div class="kpi-value">{{ latestSeo.clicks|default(0)|number_format(0, ',', ' ') }}</div>
        {% if seoTrends.clicks.value is defined and seoTrends.clicks.value %}
            <div class="kpi-trend {{ seoTrends.clicks.direction }}">
                {{ seoTrends.clicks.value }}
            </div>
        {% endif %}
    </div>

    {# CTR #}
    <div class="kpi-card accent">
        <div class="kpi-label">CTR moyen</div>
        <div class="kpi-value">{{ latestSeo.ctr is not null ? latestSeo.ctr|number_format(2) ~ '%' : 'N/A' }}</div>
        {% if seoTrends.ctr.value is defined and seoTrends.ctr.value %}
            <div class="kpi-trend {{ seoTrends.ctr.direction }}">
                {{ seoTrends.ctr.value }}
            </div>
        {% endif %}
    </div>

    {# Position moyenne #}
    <div class="kpi-card accent">
        <div class="kpi-label">Position moyenne</div>
        <div class="kpi-value">{{ latestSeo.avgPosition|default('N/A') }}</div>
        {% if seoTrends.position.value is defined and seoTrends.position.value %}
            <div class="kpi-trend {{ seoTrends.position.direction }}">
                {{ seoTrends.position.value }} positions
            </div>
        {% endif %}
    </div>

    {# Sessions organiques #}
    <div class="kpi-card success">
        <div class="kpi-label">Trafic organique</div>
        <div class="kpi-value">{{ latestSeo.organicSessions|default(0)|number_format(0, ',', ' ') }}</div>
        {% if seoTrends.organicSessions.value is defined and seoTrends.organicSessions.value %}
            <div class="kpi-trend {{ seoTrends.organicSessions.direction }}">
                {{ seoTrends.organicSessions.value }}
            </div>
        {% endif %}
    </div>

    {# Utilisateurs uniques #}
    <div class="kpi-card success">
        <div class="kpi-label">Utilisateurs uniques</div>
        <div class="kpi-value">{{ latestSeo.totalUsers|default(0)|number_format(0, ',', ' ') }}</div>
        {% if seoTrends.totalUsers.value is defined and seoTrends.totalUsers.value %}
            <div class="kpi-trend {{ seoTrends.totalUsers.direction }}">
                {{ seoTrends.totalUsers.value }}
            </div>
        {% endif %}
    </div>

    {# Taux de rebond #}
    <div class="kpi-card warning">
        <div class="kpi-label">Taux de rebond</div>
        <div class="kpi-value">{{ latestSeo.bounceRate is not null ? latestSeo.bounceRate|number_format(1) ~ '%' : 'N/A' }}</div>
        {% if seoTrends.bounceRate.value is defined and seoTrends.bounceRate.value %}
            <div class="kpi-trend {{ seoTrends.bounceRate.direction }}">
                {{ seoTrends.bounceRate.value }}
            </div>
        {% endif %}
    </div>

    {# Engagement #}
    <div class="kpi-card warning">
        <div class="kpi-label">Engagement</div>
        <div class="kpi-value">{{ latestSeo.engagementRate is not null ? latestSeo.engagementRate|number_format(1) ~ '%' : 'N/A' }}</div>
        {% if seoTrends.engagementRate.value is defined and seoTrends.engagementRate.value %}
            <div class="kpi-trend {{ seoTrends.engagementRate.direction }}">
                {{ seoTrends.engagementRate.value }}
            </div>
        {% endif %}
    </div>
</div>

{# ===== Graphiques SEO ===== #}
{% if seoChartData.labels|length > 1 %}
<div class="charts-grid">
    <div class="chart-card">
        <h3>Évolution des impressions & clics</h3>
        <canvas id="seoTrafficChart"></canvas>
    </div>
    <div class="chart-card">
        <h3>Trafic organique & utilisateurs</h3>
        <canvas id="seoSessionsChart"></canvas>
    </div>
</div>
{% endif %}

{% else %}
<div class="section-header">
    <div class="section-icon seo">📊</div>
    <h2>Performance SEO</h2>
</div>
<div class="empty-state">
    <h3>🔍 Aucune métrique SEO disponible</h3>
    <p>
        Lancez la commande <code>php bin/console app:sync-metrics</code> pour extraire les KPIs depuis vos rapports HTML existants.
    </p>
</div>
{% endif %}


{# ===== SECTION : LinkedIn ===== #}
<div class="section-header">
    <div class="section-icon linkedin">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
    </div>
    <h2>LinkedIn</h2>
</div>

{% if latestLinkedin %}
    {# LinkedIn Banner #}
    <div class="linkedin-banner">
        <div class="li-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
        </div>
        <div class="li-content">
            <h3>Présence LinkedIn — {{ latestLinkedin.monthName }}</h3>
            <p>
                {% if latestLinkedin.notes %}
                    {{ latestLinkedin.notes }}
                {% else %}
                    Suivi mensuel de la visibilité et de l'engagement sur LinkedIn.
                {% endif %}
            </p>
        </div>
        <div class="li-stats">
            {% if latestLinkedin.linkedinFollowers %}
                <div class="li-stat">
                    <span class="li-stat-value">{{ latestLinkedin.linkedinFollowers|number_format(0, ',', ' ') }}</span>
                    <span class="li-stat-label">Abonnés</span>
                </div>
            {% endif %}
            {% if latestLinkedin.linkedinPostsPublished %}
                <div class="li-stat">
                    <span class="li-stat-value">{{ latestLinkedin.linkedinPostsPublished }}</span>
                    <span class="li-stat-label">Posts</span>
                </div>
            {% endif %}
            {% if latestLinkedin.linkedinImpressions %}
                <div class="li-stat">
                    <span class="li-stat-value">{{ latestLinkedin.linkedinImpressions|number_format(0, ',', ' ') }}</span>
                    <span class="li-stat-label">Impressions</span>
                </div>
            {% endif %}
        </div>
    </div>

    {# LinkedIn KPIs #}
    <div class="kpi-grid compact">
        {% if latestLinkedin.linkedinFollowers %}
        <div class="kpi-card linkedin">
            <div class="kpi-label">Abonnés</div>
            <div class="kpi-value">{{ latestLinkedin.linkedinFollowers|number_format(0, ',', ' ') }}</div>
            {% if linkedinTrends.followers.value is defined and linkedinTrends.followers.value %}
                <div class="kpi-trend {{ linkedinTrends.followers.direction }}">{{ linkedinTrends.followers.value }}</div>
            {% endif %}
        </div>
        {% endif %}

        {% if latestLinkedin.linkedinImpressions %}
        <div class="kpi-card linkedin">
            <div class="kpi-label">Impressions</div>
            <div class="kpi-value">{{ latestLinkedin.linkedinImpressions|number_format(0, ',', ' ') }}</div>
            {% if linkedinTrends.impressions.value is defined and linkedinTrends.impressions.value %}
                <div class="kpi-trend {{ linkedinTrends.impressions.direction }}">{{ linkedinTrends.impressions.value }}</div>
            {% endif %}
        </div>
        {% endif %}

        {% if latestLinkedin.linkedinReactions %}
        <div class="kpi-card linkedin">
            <div class="kpi-label">Réactions</div>
            <div class="kpi-value">{{ latestLinkedin.linkedinReactions|number_format(0, ',', ' ') }}</div>
            {% if linkedinTrends.reactions.value is defined and linkedinTrends.reactions.value %}
                <div class="kpi-trend {{ linkedinTrends.reactions.direction }}">{{ linkedinTrends.reactions.value }}</div>
            {% endif %}
        </div>
        {% endif %}

        {% if latestLinkedin.linkedinProfileViews %}
        <div class="kpi-card linkedin">
            <div class="kpi-label">Vues de profil</div>
            <div class="kpi-value">{{ latestLinkedin.linkedinProfileViews|number_format(0, ',', ' ') }}</div>
        </div>
        {% endif %}

        {% if latestLinkedin.linkedinEngagementRate %}
        <div class="kpi-card linkedin">
            <div class="kpi-label">Taux d'engagement</div>
            <div class="kpi-value">{{ latestLinkedin.linkedinEngagementRate|number_format(1) }}%</div>
            {% if linkedinTrends.engagementRate.value is defined and linkedinTrends.engagementRate.value %}
                <div class="kpi-trend {{ linkedinTrends.engagementRate.direction }}">{{ linkedinTrends.engagementRate.value }}</div>
            {% endif %}
        </div>
        {% endif %}

        {% if latestLinkedin.linkedinComments %}
        <div class="kpi-card linkedin">
            <div class="kpi-label">Commentaires</div>
            <div class="kpi-value">{{ latestLinkedin.linkedinComments }}</div>
        </div>
        {% endif %}

        {% if latestLinkedin.linkedinShares %}
        <div class="kpi-card linkedin">
            <div class="kpi-label">Partages</div>
            <div class="kpi-value">{{ latestLinkedin.linkedinShares }}</div>
        </div>
        {% endif %}
    </div>

{% else %}
    <div class="empty-state">
        <h3>💼 Données LinkedIn</h3>
        <p>
            Les métriques LinkedIn seront affichées ici une fois saisies.<br>
            <small style="color: var(--text-secondary);">
                Prochainement : gestion via EasyAdmin.
                En attendant, créez une entrée <code>PerformanceMetric</code> avec source <code>linkedin</code>.
            </small>
        </p>
    </div>
{% endif %}


{# ===== SECTION : Rapports récents ===== #}
<div class="section-header">
    <div class="section-icon reports">📋</div>
    <h2>Rapports récents</h2>
</div>

{% if reports is empty %}
    <div class="empty-state">
        <h3>📭 Aucun rapport disponible</h3>
        <p>
            Placez vos fichiers HTML dans <code>public/reports/</code> puis exécutez <code>php bin/console app:sync-reports</code>.
        </p>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_reports_sync') }}" class="btn btn-primary" style="margin-top: 1rem;">
                Synchroniser maintenant
            </a>
        {% endif %}
    </div>
{% else %}
    <div class="reports-grid">
        {% for report in reports|slice(0, 6) %}
            <a href="{{ path('app_report_view', {period: report.period}) }}" class="report-card">
                <div class="report-date">{{ report.monthName }}</div>
                <div class="report-description">{{ report.description }}</div>

                {% if report.impressions or report.organicSessions %}
                    <div class="report-mini-stats">
                        {% if report.impressions %}
                            <div class="report-mini-stat">
                                <div class="report-mini-stat-value">{{ report.impressions|number_format(0, ',', ' ') }}</div>
                                <div class="report-mini-stat-label">Impressions</div>
                            </div>
                        {% endif %}
                        {% if report.clicks %}
                            <div class="report-mini-stat">
                                <div class="report-mini-stat-value">{{ report.clicks|number_format(0, ',', ' ') }}</div>
                                <div class="report-mini-stat-label">Clics</div>
                            </div>
                        {% endif %}
                        {% if report.ctr %}
                            <div class="report-mini-stat">
                                <div class="report-mini-stat-value">{{ report.ctr|number_format(2) }}%</div>
                                <div class="report-mini-stat-label">CTR</div>
                            </div>
                        {% endif %}
                    </div>
                {% endif %}
            </a>
        {% endfor %}
    </div>

    {% if totalReports > 6 %}
        <div class="view-all-link">
            <a href="{{ path('app_reports_list') }}" class="btn btn-primary">
                Voir tous les rapports ({{ totalReports }})
            </a>
        </div>
    {% endif %}
{% endif %}

{% endblock %}

{% block javascripts %}
    {{ parent() }}

    {% if seoChartData.labels|default([])|length > 1 %}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const chartDefaults = {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        usePointStyle: true,
                        padding: 16,
                        font: { family: 'Inter', size: 12 }
                    }
                }
            },
            scales: {
                x: {
                    grid: { display: false },
                    ticks: { font: { family: 'Inter', size: 11 } }
                },
                y: {
                    grid: { color: '#f1f5f9' },
                    ticks: { font: { family: 'Inter', size: 11 } }
                }
            }
        };

        // Impressions & Clics
        new Chart(document.getElementById('seoTrafficChart'), {
            type: 'bar',
            data: {
                labels: {{ seoChartData.labels|json_encode|raw }},
                datasets: [
                    {
                        label: 'Impressions',
                        data: {{ seoChartData.datasets.impressions|json_encode|raw }},
                        backgroundColor: 'rgba(30, 58, 138, 0.7)',
                        borderRadius: 6,
                        barPercentage: 0.6,
                    },
                    {
                        label: 'Clics',
                        data: {{ seoChartData.datasets.clicks|json_encode|raw }},
                        backgroundColor: 'rgba(6, 182, 212, 0.7)',
                        borderRadius: 6,
                        barPercentage: 0.6,
                    }
                ]
            },
            options: chartDefaults
        });

        // Sessions & Utilisateurs
        new Chart(document.getElementById('seoSessionsChart'), {
            type: 'line',
            data: {
                labels: {{ seoChartData.labels|json_encode|raw }},
                datasets: [
                    {
                        label: 'Sessions organiques',
                        data: {{ seoChartData.datasets.organicSessions|json_encode|raw }},
                        borderColor: '#059669',
                        backgroundColor: 'rgba(5, 150, 105, 0.1)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                    },
                    {
                        label: 'Utilisateurs uniques',
                        data: {{ seoChartData.datasets.totalUsers|json_encode|raw }},
                        borderColor: '#F59E0B',
                        backgroundColor: 'rgba(245, 158, 11, 0.1)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                    }
                ]
            },
            options: chartDefaults
        });
    </script>
    {% endif %}
{% endblock %}
